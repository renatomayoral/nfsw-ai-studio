# =============================================================================
# NFSW AI Studio — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# =============================================================================

# -----------------------------------------------------------------------------
# GCP — autenticação via application-default (gcloud auth application-default login)
# Não é necessário service account key file
# -----------------------------------------------------------------------------
GCP_PROJECT=mktia-ai-studio
GCP_ZONE=us-central1-a
GCP_INSTANCE_NAME=ai-studio-vm

# -----------------------------------------------------------------------------
# Google Cloud Storage
# -----------------------------------------------------------------------------
GCS_BUCKET=mktia-ai-studio-outputs

# -----------------------------------------------------------------------------
# RunPod (opcional — preencher apenas se usar RunPod como provider)
# -----------------------------------------------------------------------------
RUNPOD_API_KEY=

# -----------------------------------------------------------------------------
# HuggingFace (para download dos modelos ~100GB)
# Obter em: https://huggingface.co/settings/tokens
# -----------------------------------------------------------------------------
HF_TOKEN=

# -----------------------------------------------------------------------------
# ComfyUI — acessado via SSH tunnel local
# gcloud compute ssh $GCP_INSTANCE_NAME --project=$GCP_PROJECT -- -L 8188:localhost:8188
# -----------------------------------------------------------------------------
COMFYUI_URL=http://localhost:8188

# -----------------------------------------------------------------------------
# Provider ativo
# -----------------------------------------------------------------------------
CLOUD_PROVIDER=gcp
# CLOUD_PROVIDER=runpod
