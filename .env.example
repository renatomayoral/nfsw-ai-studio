# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL and domain of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# ─── Auth (Better Auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database (Postgres) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Stripe (fiat card subscriptions + Connect) ───────────────────────────────
# Use a Restricted API key (rk_) with: Products/Prices, Checkout, Connect,
# Subscriptions, Webhooks. Connect (Express) must be enabled on the account.
STRIPE_SECRET_KEY=
# Signing secret from the webhook endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Platform subscription Price ids (the SaaS plans, not creator VIP plans)
STRIPE_PRICE_SPARK=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_PRO=

# ─── NOWPayments (crypto subscriptions — optional second rail) ─────────────────
# API key from the NOWPayments dashboard (Store settings)
NOWPAYMENTS_API_KEY=
# IPN secret used to verify webhook callback signatures
NOWPAYMENTS_IPN_SECRET=
